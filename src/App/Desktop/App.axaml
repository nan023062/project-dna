<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Dna.App.Desktop.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="Background" Value="#181818" />
            <Setter Property="FontFamily" Value="avares://Avalonia.Fonts.Inter#Inter" />
        </Style>

        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="avares://Avalonia.Fonts.Inter#Inter" />
            <Setter Property="Foreground" Value="#CCCCCC" />
        </Style>

        <Style Selector="Border.shellSurface">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="BorderBrush" Value="#2D2D30" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style Selector="Border.panelSurface">
            <Setter Property="Background" Value="#202225" />
            <Setter Property="BorderBrush" Value="#2D2D30" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="Border.innerSurface">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="BorderBrush" Value="#333337" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="Border.detailSurface">
            <Setter Property="Background" Value="#1F1F22" />
            <Setter Property="BorderBrush" Value="#2D2D30" />
            <Setter Property="BorderThickness" Value="1,1,0,0" />
            <Setter Property="CornerRadius" Value="0,0,10,10" />
        </Style>

        <Style Selector="Border.metricSurface">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="BorderBrush" Value="#333337" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="Border.graphSurface">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="BorderBrush" Value="#2D2D30" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="Border.sidebarPanel">
            <Setter Property="MinWidth" Value="240" />
        </Style>

        <Style Selector="Border.titleBarSurface">
            <Setter Property="Background" Value="#181818" />
            <Setter Property="BorderBrush" Value="#2D2D30" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style Selector="Border.menuBarSurface">
            <Setter Property="Background" Value="#181818" />
            <Setter Property="BorderBrush" Value="#2D2D30" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style Selector="Menu.workspaceMenu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#D4D4D4" />
        </Style>

        <Style Selector="Menu.workspaceMenu /template/ ContentPresenter">
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style Selector="MenuItem">
            <Setter Property="Foreground" Value="#D4D4D4" />
        </Style>

        <Style Selector="MenuItem:pointerover">
            <Setter Property="Background" Value="#2A2D2E" />
        </Style>

        <Style Selector="Border.panelHeader">
            <Setter Property="Background" Value="#1F1F22" />
            <Setter Property="BorderBrush" Value="#2D2D30" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="CornerRadius" Value="10,10,0,0" />
        </Style>

        <Style Selector="Border.brandBadge">
            <Setter Property="Background" Value="#0E639C" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style Selector="TextBlock.brandBadgeText">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="Border.statusPill">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="BorderBrush" Value="#333337" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style Selector="TextBlock.statusPillText">
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="TextBlock.heroTitle">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="TextBlock.titleBarLabel">
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.titleBarTitle">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.panelEyebrow">
            <Setter Property="Foreground" Value="#858585" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.cardTitle">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.primaryText">
            <Setter Property="Foreground" Value="#D4D4D4" />
        </Style>

        <Style Selector="TextBlock.secondaryText">
            <Setter Property="Foreground" Value="#B9B9B9" />
        </Style>

        <Style Selector="TextBlock.mutedText">
            <Setter Property="Foreground" Value="#9D9D9D" />
        </Style>

        <Style Selector="TextBlock.tertiaryText">
            <Setter Property="Foreground" Value="#7F7F7F" />
        </Style>

        <Style Selector="TextBlock.metricValue">
            <Setter Property="Foreground" Value="#4FC1FF" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="TextBlock.formLabel">
            <Setter Property="Foreground" Value="#9D9D9D" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.explorerIcon">
            <Setter Property="Foreground" Value="#D7BA7D" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Margin" Value="0,1,0,0" />
        </Style>

        <Style Selector="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="#2A2D2E" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#313438" />
            <Setter Property="BorderBrush" Value="#4A4A4A" />
        </Style>

        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#37373D" />
        </Style>

        <Style Selector="Button.primaryAction">
            <Setter Property="Background" Value="#0E639C" />
            <Setter Property="BorderBrush" Value="#1177BB" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.primaryAction:pointerover">
            <Setter Property="Background" Value="#1177BB" />
            <Setter Property="BorderBrush" Value="#1386D3" />
        </Style>

        <Style Selector="Button.quietIcon">
            <Setter Property="MinWidth" Value="26" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="Button.chatModeButton.active">
            <Setter Property="Background" Value="#0E639C" />
            <Setter Property="BorderBrush" Value="#1177BB" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="TreeView.workspaceExplorer">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4,8,8" />
        </Style>

        <Style Selector="TreeView.workspaceExplorer TreeViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="MinHeight" Value="24" />
        </Style>

        <Style Selector="TreeView.workspaceExplorer TreeViewItem:pointerover">
            <Setter Property="Background" Value="#2A2D2E" />
        </Style>

        <Style Selector="TreeView.workspaceExplorer TreeViewItem:selected">
            <Setter Property="Background" Value="#37373D" />
        </Style>

        <Style Selector="TextBlock.explorerGlyph">
            <Setter Property="Foreground" Value="#C5C5C5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.explorerLabel">
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBox.logViewer">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="BorderBrush" Value="#1E1E1E" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Background" Value="#252526" />
            <Setter Property="BorderBrush" Value="#333337" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="#2A2D2E" />
            <Setter Property="BorderBrush" Value="#45454A" />
        </Style>

        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="#1F3A4A" />
            <Setter Property="BorderBrush" Value="#0E639C" />
        </Style>

        <Style Selector="TabControl.workspaceTabs">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#252526" />
            <Setter Property="TabStripPlacement" Value="Top" />
        </Style>

        <Style Selector="TabControl.workspaceTabs TabItem">
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="MinHeight" Value="34" />
        </Style>

        <Style Selector="TabItem">
            <Setter Property="Background" Value="#1F1F22" />
            <Setter Property="BorderBrush" Value="#2D2D30" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#9D9D9D" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="CornerRadius" Value="8,8,0,0" />
        </Style>

        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="CheckBox.filterChip">
            <Setter Property="Foreground" Value="#B9B9B9" />
        </Style>

        <Style Selector="GridSplitter.shellSplitter">
            <Setter Property="Background" Value="#2D2D30" />
        </Style>

        <Style Selector="Border.chatBubble">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="MaxWidth" Value="320" />
        </Style>

        <Style Selector="Border.chatBubble.user">
            <Setter Property="Background" Value="#0E639C" />
            <Setter Property="BorderBrush" Value="#1177BB" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Border.chatBubble.assistant">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="BorderBrush" Value="#333337" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="TextBlock.chatBubbleText.user">
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="TextBlock.chatBubbleText.assistant">
            <Setter Property="Foreground" Value="#D4D4D4" />
        </Style>
    </Application.Styles>
</Application>
