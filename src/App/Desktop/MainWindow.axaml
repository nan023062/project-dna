<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:desktop="clr-namespace:Dna.App.Desktop"
        mc:Ignorable="d"
        d:DesignWidth="1520"
        d:DesignHeight="980"
        x:Class="Dna.App.Desktop.MainWindow"
        Title="Agentic OS"
        MinWidth="1280"
        MinHeight="820">
    <Grid>
        <Border x:Name="ProjectLoadPanel"
                Classes="shellSurface"
                Padding="28"
                Margin="24"
                IsVisible="True">
            <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="18">
                <StackPanel Spacing="8">
                    <TextBlock Classes="heroTitle" Text="Open Workspace" />
                    <TextBlock Classes="mutedText"
                               TextWrapping="Wrap"
                               Text="Choose any workspace folder. Agentic OS will create or reuse .agentic-os automatically and enter the single-process desktop shell." />
                </StackPanel>

                <WrapPanel Grid.Row="1" Orientation="Horizontal">
                    <Button Classes="primaryAction"
                            Content="Open Folder..."
                            Click="OpenProjectFolder_OnClick"
                            Margin="0,0,8,0" />
                </WrapPanel>

                <Grid Grid.Row="2" ColumnDefinitions="1.5*,1*" ColumnSpacing="18">
                    <Border Classes="panelSurface" Padding="16">
                        <Grid RowDefinitions="Auto,*" RowSpacing="12">
                            <TextBlock x:Name="RecentCountText"
                                       Classes="sectionTitle"
                                       Text="Recent Projects" />
                            <ListBox Grid.Row="1"
                                     x:Name="RecentProjectsListBox"
                                     SelectionChanged="RecentProjectsListBox_OnSelectionChanged"
                                     DoubleTapped="RecentProjectsListBox_OnDoubleTapped">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:CompileBindings="False">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="cardTitle" Text="{Binding Title}" />
                                                <TextBlock Classes="secondaryText"
                                                           Text="{Binding ProjectRoot}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Classes="quietIcon"
                                                    Width="26"
                                                    Height="26"
                                                    Padding="0"
                                                    Tag="{Binding ProjectRoot}"
                                                    Content="-"
                                                    Click="RecentProjectRemoveButton_OnClick" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Classes="panelSurface" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="sectionTitle" Text="Project Summary" />
                            <TextBlock x:Name="RecentProjectHintText"
                                       Classes="secondaryText"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="LoaderStatusText"
                                       Classes="mutedText"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="3"
                           Classes="tertiaryText"
                           TextWrapping="Wrap"
                           Text="Double-click a recent project to enter directly. Remove an item with the trailing '-' button." />
            </Grid>
        </Border>

        <Grid x:Name="WorkspacePanel"
              IsVisible="False"
              RowDefinitions="Auto,*">
            <Border Grid.Row="0" Classes="menuBarSurface" Padding="8,4">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Menu Classes="workspaceMenu">
                        <MenuItem Header="_Project">
                            <MenuItem Header="Switch Workspace..." Click="MenuSwitchWorkspace_OnClick" />
                            <MenuItem Header="Open Folder..." Click="OpenProjectFolder_OnClick" />
                            <Separator />
                            <MenuItem Header="Exit" Click="MenuExit_OnClick" />
                        </MenuItem>
                        <MenuItem Header="_View">
                            <MenuItem Header="Refresh Explorer" Click="RefreshWorkspaceTree_OnClick" />
                            <MenuItem Header="Refresh Graph" Click="RefreshTopology_OnClick" />
                            <MenuItem Header="Refresh Memory" Click="RefreshMemories_OnClick" />
                            <Separator />
                            <MenuItem Header="Refresh Recent" Click="ReloadRecentProjects_OnClick" />
                        </MenuItem>
                    </Menu>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <StackPanel IsVisible="False">
                            <TextBlock x:Name="SelectedProjectText" />
                            <TextBlock x:Name="LaunchModeText" />
                        </StackPanel>
                        <Border Classes="statusPill"><TextBlock x:Name="AppStateText" Classes="statusPillText" Text="App: offline" /></Border>
                        <Border Classes="statusPill"><TextBlock x:Name="ServerStateText" Classes="statusPillText" Text="Knowledge: -" /></Border>
                        <Border Classes="statusPill"><TextBlock x:Name="AccessStateText" Classes="statusPillText" Text="Access: -" /></Border>
                    </StackPanel>
                </Grid>
            </Border>

            <desktop:WorkbenchSplitLayout Grid.Row="1"
                                          Orientation="Horizontal"
                                          PrimaryLength="300">
                <desktop:WorkbenchSplitLayout.First>
                    <desktop:WorkbenchSplitLayout Orientation="Vertical"
                                                  PrimaryLength="*">
                        <desktop:WorkbenchSplitLayout.First>
                            <desktop:WorkbenchWindow x:Name="WorkspaceExplorerWindow"
                                                     Title="Workspace Tree">
                                <desktop:WorkbenchWindow.WindowContent>
                                    <Grid RowDefinitions="Auto,*" RowSpacing="0">
                                        <StackPanel IsVisible="False">
                                            <TextBlock x:Name="WorkspaceTreeSummaryText" Text="WorkspaceEngine Snapshot" />
                                            <TextBlock x:Name="WorkspaceProjectPathText" Text="-" />
                                        </StackPanel>

                                        <Border Grid.Row="1" Background="Transparent" Padding="0">
                                            <TreeView x:Name="WorkspaceTreeView"
                                                      Classes="workspaceExplorer"
                                                      SelectionChanged="WorkspaceTreeView_OnSelectionChanged">
                                                <TreeView.ItemTemplate>
                                                    <TreeDataTemplate x:CompileBindings="False" ItemsSource="{Binding Children}">
                                                        <Grid ColumnDefinitions="Auto,*"
                                                              ColumnSpacing="8"
                                                              Margin="6,1,8,1"
                                                              Tapped="WorkspaceTreeNode_OnTapped">
                                                            <TextBlock Grid.Column="0" Classes="explorerGlyph" Text="{Binding Icon}" />
                                                            <TextBlock Grid.Column="1" Classes="explorerLabel" Text="{Binding DisplayName}" />
                                                        </Grid>
                                                    </TreeDataTemplate>
                                                </TreeView.ItemTemplate>
                                            </TreeView>
                                        </Border>
                                    </Grid>
                                </desktop:WorkbenchWindow.WindowContent>
                            </desktop:WorkbenchWindow>
                        </desktop:WorkbenchSplitLayout.First>

                        <desktop:WorkbenchSplitLayout.Second>
                            <desktop:WorkbenchWindow Title="文件元数据">
                                <desktop:WorkbenchWindow.WindowContent>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Margin="12" Spacing="8">
                                            <TextBlock x:Name="WorkspaceSelectionTitleText"
                                                       Classes="cardTitle"
                                                       Text="Nothing selected" />
                                            <TextBlock x:Name="WorkspaceSelectionMetaText"
                                                       Classes="secondaryText"
                                                       TextWrapping="Wrap"
                                                       Text="Select a folder or file from the WorkspaceEngine tree." />
                                            <TextBlock x:Name="WorkspaceSelectionPathText"
                                                       Classes="mutedText"
                                                       TextWrapping="Wrap"
                                                       Text="-" />
                                            <TextBlock x:Name="WorkspaceSelectionBadgeText"
                                                       Classes="tertiaryText"
                                                       TextWrapping="Wrap"
                                                       Text="" />
                                            <TextBlock x:Name="WorkspaceSelectionActionText"
                                                       Classes="tertiaryText"
                                                       TextWrapping="Wrap"
                                                       Text="" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </desktop:WorkbenchWindow.WindowContent>
                            </desktop:WorkbenchWindow>
                        </desktop:WorkbenchSplitLayout.Second>
                    </desktop:WorkbenchSplitLayout>
                </desktop:WorkbenchSplitLayout.First>

                <desktop:WorkbenchSplitLayout.Second>
                    <desktop:WorkbenchSplitLayout Orientation="Vertical"
                                                  PrimaryLength="*">
                        <desktop:WorkbenchSplitLayout.First>
                            <desktop:WorkbenchSplitLayout Orientation="Horizontal"
                                                          PrimaryLength="*">
                                <desktop:WorkbenchSplitLayout.First>
                                    <desktop:WorkbenchWindow Title="知识工作台">
                                        <desktop:WorkbenchWindow.WindowContent>
                                            <desktop:WorkbenchTabLayout x:Name="WorkspaceTabs" SelectedIndex="1">
                                                <desktop:WorkbenchTab Title="记忆">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <StackPanel Margin="16" Spacing="14">
                                                            <StackPanel IsVisible="False">
                                                                <TextBlock x:Name="OverviewModeText" />
                                                                <TextBlock x:Name="StatusText" />
                                                                <TextBlock x:Name="OverviewPrimaryActionText" />
                                                                <TextBlock x:Name="OverviewWorkflowText" />
                                                                <TextBlock x:Name="OverviewRecommendationText" />
                                                                <TextBlock x:Name="ConnectionStatusText" />
                                                                <TextBlock x:Name="ConnectionRoleText" />
                                                                <TextBlock x:Name="ConnectionIpText" />
                                                                <TextBlock x:Name="ConnectionServerText" />
                                                                <TextBlock x:Name="ConnectionNoteText" />
                                                                <TextBlock x:Name="ConnectionRecommendationText" />
                                                            </StackPanel>

                                                            <Border Classes="innerSurface" Padding="16">
                                                                <StackPanel Spacing="8">
                                                                    <TextBlock Classes="sectionTitle" Text="Short-Term Memory" />
                                                                    <TextBlock x:Name="MemoryAccessText"
                                                                               Classes="mutedText"
                                                                               TextWrapping="Wrap"
                                                                               Text="Memory access pending." />
                                                                </StackPanel>
                                                            </Border>

                                                            <Grid ColumnDefinitions="360,*" ColumnSpacing="12">
                                                                <Border Classes="innerSurface" Padding="16">
                                                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="8">
                                                                        <WrapPanel Orientation="Horizontal">
                                                                            <Button Classes="primaryAction"
                                                                                    Content="Refresh Memory"
                                                                                    Click="RefreshMemories_OnClick" />
                                                                        </WrapPanel>

                                                                        <Grid Grid.Row="1" ColumnDefinitions="Auto,120,Auto,*,Auto,120" ColumnSpacing="8">
                                                                            <TextBlock Grid.Column="0" Classes="formLabel" VerticalAlignment="Center" Text="Type" />
                                                                            <ComboBox Grid.Column="1" x:Name="MemoryTypeBox" SelectedIndex="2">
                                                                                <ComboBoxItem Content="Structural" />
                                                                                <ComboBoxItem Content="Semantic" />
                                                                                <ComboBoxItem Content="Episodic" />
                                                                                <ComboBoxItem Content="Working" />
                                                                                <ComboBoxItem Content="Procedural" />
                                                                            </ComboBox>
                                                                            <TextBlock Grid.Column="2" Classes="formLabel" VerticalAlignment="Center" Text="Tags" />
                                                                            <TextBox Grid.Column="3" x:Name="MemoryTagsBox" Watermark="#desktop-note,#decision" />
                                                                            <TextBlock Grid.Column="4" Classes="formLabel" VerticalAlignment="Center" Text="Discipline" />
                                                                            <TextBox Grid.Column="5" x:Name="MemoryDisciplineBox" Text="engineering" />
                                                                        </Grid>

                                                                        <TextBox Grid.Row="2"
                                                                                 x:Name="MemoryContentBox"
                                                                                 AcceptsReturn="True"
                                                                                 Height="96"
                                                                                 TextWrapping="Wrap"
                                                                                 Watermark="Write a short-term memory..." />

                                                                        <WrapPanel Grid.Row="3" Orientation="Horizontal">
                                                                            <Button x:Name="AddMemoryButton" Classes="primaryAction" Content="Remember" Click="AddMemory_OnClick" />
                                                                        </WrapPanel>

                                                                        <TextBlock Grid.Row="4" x:Name="MemoryStatusText" Classes="mutedText" TextWrapping="Wrap" Text="Memory area ready." />
                                                                    </Grid>
                                                                </Border>

                                                                <Border Grid.Column="1" Classes="innerSurface" Padding="16">
                                                                    <StackPanel Spacing="8">
                                                                        <TextBlock Classes="sectionTitle" Text="Recent Memory" />
                                                                        <ListBox x:Name="MemoryListBox" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </Grid>
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </desktop:WorkbenchTab>
                                                <desktop:WorkbenchTab Title="知识拓扑图">
                                                    <Grid Margin="16" RowDefinitions="Auto,Auto,*" RowSpacing="12">
                                                        <StackPanel Spacing="8">
                                                            <WrapPanel Orientation="Horizontal">
                                                                <Button Classes="primaryAction"
                                                                        Content="Refresh Graph"
                                                                        Click="RefreshTopology_OnClick"
                                                                        Margin="0,0,8,0" />
                                                                <Button Content="Root View"
                                                                        Click="TopologyNavigateRoot_OnClick"
                                                                        Margin="0,0,12,0" />
                                                                <CheckBox Classes="filterChip"
                                                                          x:Name="TopologyDependencyFilter"
                                                                          IsChecked="True"
                                                                          Content="Dependency"
                                                                          Margin="0,0,8,0"
                                                                          Checked="TopologyFilter_OnChanged"
                                                                          Unchecked="TopologyFilter_OnChanged" />
                                                                <CheckBox Classes="filterChip"
                                                                          x:Name="TopologyCompositionFilter"
                                                                          IsChecked="True"
                                                                          Content="Composition"
                                                                          Margin="0,0,8,0"
                                                                          Checked="TopologyFilter_OnChanged"
                                                                          Unchecked="TopologyFilter_OnChanged" />
                                                                <CheckBox Classes="filterChip"
                                                                          x:Name="TopologyAggregationFilter"
                                                                          IsChecked="True"
                                                                          Content="Aggregation"
                                                                          Margin="0,0,8,0"
                                                                          Checked="TopologyFilter_OnChanged"
                                                                          Unchecked="TopologyFilter_OnChanged" />
                                                                <CheckBox Classes="filterChip"
                                                                          x:Name="TopologyParentChildFilter"
                                                                          IsChecked="True"
                                                                          Content="Parent / Child"
                                                                          Margin="0,0,8,0"
                                                                          Checked="TopologyFilter_OnChanged"
                                                                          Unchecked="TopologyFilter_OnChanged" />
                                                                <CheckBox Classes="filterChip"
                                                                          x:Name="TopologyCollaborationFilter"
                                                                          IsChecked="True"
                                                                          Content="Collaboration"
                                                                          Checked="TopologyFilter_OnChanged"
                                                                          Unchecked="TopologyFilter_OnChanged" />
                                                            </WrapPanel>
                                                            <TextBlock x:Name="TopologySummaryText"
                                                                       Classes="mutedText"
                                                                       TextWrapping="Wrap"
                                                                       Text="Topology not loaded." />
                                                            <TextBlock x:Name="TopologyScopeText"
                                                                       Classes="secondaryText"
                                                                       TextWrapping="Wrap"
                                                                       Text="Current scope: root" />
                                                        </StackPanel>

                                                        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                                                            <Border Classes="metricSurface" Padding="12">
                                                                <StackPanel Spacing="4">
                                                                    <TextBlock Classes="mutedText" Text="Nodes" />
                                                                    <TextBlock x:Name="StatModulesText" Classes="metricValue" Text="-" />
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Grid.Column="1" Classes="metricSurface" Padding="12">
                                                                <StackPanel Spacing="4">
                                                                    <TextBlock Classes="mutedText" Text="Dependencies" />
                                                                    <TextBlock x:Name="StatDependenciesText" Classes="metricValue" Text="-" />
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Grid.Column="2" Classes="metricSurface" Padding="12">
                                                                <StackPanel Spacing="4">
                                                                    <TextBlock Classes="mutedText" Text="Collaboration" />
                                                                    <TextBlock x:Name="StatCollaborationText" Classes="metricValue" Text="-" />
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Grid.Column="3" Classes="metricSurface" Padding="12">
                                                                <StackPanel Spacing="4">
                                                                    <TextBlock Classes="mutedText" Text="Disciplines" />
                                                                    <TextBlock x:Name="StatDisciplinesText" Classes="metricValue" Text="-" />
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>

                                                        <Grid Grid.Row="2" ColumnDefinitions="2.2*,1.1*" ColumnSpacing="12">
                                                            <Border Classes="graphSurface" Padding="10">
                                                                <desktop:TopologyGraphControl x:Name="TopologyGraph" />
                                                            </Border>

                                                            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                                                                <StackPanel Spacing="12">
                                                                    <Border Classes="innerSurface" Padding="14">
                                                                        <StackPanel Spacing="6">
                                                                            <TextBlock x:Name="TopologyDetailTitle"
                                                                                       Classes="cardTitle"
                                                                                       FontSize="18"
                                                                                       Text="No node selected" />
                                                                            <TextBlock x:Name="TopologyDetailMeta"
                                                                                       Classes="mutedText"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="-" />
                                                                            <TextBlock x:Name="TopologyDetailSummary"
                                                                                       Classes="secondaryText"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="Select a node in the graph." />
                                                                        </StackPanel>
                                                                    </Border>

                                                                    <Border Classes="innerSurface" Padding="14">
                                                                        <StackPanel Spacing="8">
                                                                            <TextBlock Classes="sectionTitle" Text="Module Editor" />
                                                                            <TextBlock x:Name="TopologyEditHintText"
                                                                                       Classes="mutedText"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="Select a module node to edit its definition." />
                                                                            <TextBlock x:Name="TopologyEditParallelHintText"
                                                                                       Classes="tertiaryText"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="Manual save and MCP upsert_module share the same write path." />
                                                                            <TextBlock Classes="formLabel" Text="Discipline" />
                                                                            <ComboBox x:Name="TopologyEditDisciplineBox" />
                                                                            <TextBlock Classes="formLabel" Text="Layer" />
                                                                            <TextBox x:Name="TopologyEditLayerBox" />
                                                                            <TextBlock Classes="formLabel" Text="Name" />
                                                                            <TextBox x:Name="TopologyEditNameBox" />
                                                                            <TextBlock Classes="formLabel" Text="Path" />
                                                                            <TextBox x:Name="TopologyEditPathBox" />
                                                                            <TextBlock Classes="formLabel" Text="Parent Module" />
                                                                            <ComboBox x:Name="TopologyEditParentBox" />
                                                                            <TextBlock Classes="formLabel" Text="Managed Paths" />
                                                                            <TextBox x:Name="TopologyEditManagedPathsBox"
                                                                                     AcceptsReturn="True"
                                                                                     Height="56"
                                                                                     TextWrapping="Wrap" />
                                                                            <TextBlock Classes="formLabel" Text="Maintainer" />
                                                                            <TextBox x:Name="TopologyEditMaintainerBox" />
                                                                            <TextBlock Classes="formLabel" Text="Summary" />
                                                                            <TextBox x:Name="TopologyEditSummaryBox"
                                                                                     AcceptsReturn="True"
                                                                                     Height="56"
                                                                                     TextWrapping="Wrap" />
                                                                            <TextBlock Classes="formLabel" Text="Boundary" />
                                                                            <ComboBox x:Name="TopologyEditBoundaryBox" SelectedIndex="0">
                                                                                <ComboBoxItem Content="" />
                                                                                <ComboBoxItem Content="open" />
                                                                                <ComboBoxItem Content="semi-open" />
                                                                                <ComboBoxItem Content="closed" />
                                                                            </ComboBox>
                                                                            <TextBlock Classes="formLabel" Text="Dependencies" />
                                                                            <TextBox x:Name="TopologyEditDependenciesBox"
                                                                                     AcceptsReturn="True"
                                                                                     Height="56"
                                                                                     TextWrapping="Wrap" />
                                                                            <TextBlock Classes="formLabel" Text="Public API" />
                                                                            <TextBox x:Name="TopologyEditPublicApiBox"
                                                                                     AcceptsReturn="True"
                                                                                     Height="56"
                                                                                     TextWrapping="Wrap" />
                                                                            <TextBlock Classes="formLabel" Text="Constraints" />
                                                                            <TextBox x:Name="TopologyEditConstraintsBox"
                                                                                     AcceptsReturn="True"
                                                                                     Height="56"
                                                                                     TextWrapping="Wrap" />
                                                                            <TextBlock Classes="formLabel" Text="Workflow" />
                                                                            <TextBox x:Name="TopologyEditWorkflowBox"
                                                                                     AcceptsReturn="True"
                                                                                     Height="56"
                                                                                     TextWrapping="Wrap" />
                                                                            <TextBlock Classes="formLabel" Text="Rules" />
                                                                            <TextBox x:Name="TopologyEditRulesBox"
                                                                                     AcceptsReturn="True"
                                                                                     Height="56"
                                                                                     TextWrapping="Wrap" />
                                                                            <TextBlock Classes="formLabel" Text="Prohibitions" />
                                                                            <TextBox x:Name="TopologyEditProhibitionsBox"
                                                                                     AcceptsReturn="True"
                                                                                     Height="56"
                                                                                     TextWrapping="Wrap" />
                                                                            <TextBlock Classes="formLabel" Text="Metadata JSON" />
                                                                            <TextBox x:Name="TopologyEditMetadataBox"
                                                                                     AcceptsReturn="True"
                                                                                     Height="88"
                                                                                     TextWrapping="Wrap" />
                                                                            <TextBlock Classes="formLabel" Text="MCP Preview" />
                                                                            <TextBox x:Name="TopologyMcpPreviewBox"
                                                                                     AcceptsReturn="True"
                                                                                     IsReadOnly="True"
                                                                                     Height="138"
                                                                                     TextWrapping="Wrap" />
                                                                            <WrapPanel Orientation="Horizontal">
                                                                                <Button x:Name="TopologySaveModuleButton"
                                                                                        Classes="primaryAction"
                                                                                        Content="Save Module"
                                                                                        Click="SaveTopologyModule_OnClick"
                                                                                        Margin="0,0,8,0" />
                                                                                <Button x:Name="TopologyReloadLatestModuleButton"
                                                                                        Content="Reload Latest"
                                                                                        Click="RefreshTopologyModuleEditorFromServer_OnClick"
                                                                                        Margin="0,0,8,0" />
                                                                                <Button Content="Reset"
                                                                                        Click="ReloadTopologyModuleEditor_OnClick"
                                                                                        Margin="0,0,8,0" />
                                                                                <Button x:Name="CopyTopologyMcpPreviewButton"
                                                                                        Content="Copy MCP"
                                                                                        Click="CopyTopologyMcpPreview_OnClick" />
                                                                            </WrapPanel>
                                                                            <TextBlock x:Name="TopologyEditStatusText"
                                                                                       Classes="mutedText"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="Module editor ready." />
                                                                        </StackPanel>
                                                                    </Border>

                                                                    <Border Classes="innerSurface" Padding="14">
                                                                        <StackPanel Spacing="8">
                                                                            <TextBlock Classes="sectionTitle" Text="Module Knowledge" />
                                                                            <TextBlock x:Name="TopologyKnowledgeHintText"
                                                                                       Classes="mutedText"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="Select a real module to edit knowledge." />
                                                                            <TextBlock x:Name="TopologyKnowledgeParallelHintText"
                                                                                       Classes="tertiaryText"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="Manual save and MCP/CLI writes share the same storage path." />
                                                                            <TextBlock Classes="formLabel" Text="Identity" />
                                                                            <TextBox x:Name="TopologyKnowledgeIdentityBox"
                                                                                     AcceptsReturn="True"
                                                                                     Height="80"
                                                                                     TextWrapping="Wrap" />
                                                                            <TextBlock Classes="formLabel" Text="Lessons" />
                                                                            <TextBox x:Name="TopologyKnowledgeLessonsBox"
                                                                                     AcceptsReturn="True"
                                                                                     Height="72"
                                                                                     TextWrapping="Wrap" />
                                                                            <TextBlock Classes="formLabel" Text="Active Tasks" />
                                                                            <TextBox x:Name="TopologyKnowledgeActiveTasksBox"
                                                                                     AcceptsReturn="True"
                                                                                     Height="72"
                                                                                     TextWrapping="Wrap" />
                                                                            <TextBlock Classes="formLabel" Text="Facts" />
                                                                            <TextBox x:Name="TopologyKnowledgeFactsBox"
                                                                                     AcceptsReturn="True"
                                                                                     Height="72"
                                                                                     TextWrapping="Wrap" />
                                                                            <WrapPanel Orientation="Horizontal">
                                                                                <Button x:Name="TopologySaveKnowledgeButton"
                                                                                        Classes="primaryAction"
                                                                                        Content="Save Knowledge"
                                                                                        Click="SaveTopologyKnowledge_OnClick"
                                                                                        Margin="0,0,8,0" />
                                                                                <Button x:Name="TopologyReloadKnowledgeButton"
                                                                                        Content="Reload Latest"
                                                                                        Click="RefreshTopologyKnowledge_OnClick"
                                                                                        Margin="0,0,8,0" />
                                                                                <Button x:Name="TopologyResetKnowledgeButton"
                                                                                        Content="Reset Form"
                                                                                        Click="ResetTopologyKnowledgeEditor_OnClick" />
                                                                            </WrapPanel>
                                                                            <TextBlock x:Name="TopologyKnowledgeStatusText"
                                                                                       Classes="mutedText"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="Knowledge editor ready." />
                                                                        </StackPanel>
                                                                    </Border>

                                                                    <Border Classes="innerSurface" Padding="14">
                                                                        <StackPanel Spacing="8">
                                                                            <TextBlock Classes="sectionTitle" Text="Visible Nodes" />
                                                                            <ListBox x:Name="TopologyListBox"
                                                                                     MaxHeight="220"
                                                                                     SelectionChanged="TopologyListBox_OnSelectionChanged" />
                                                                        </StackPanel>
                                                                    </Border>

                                                                    <Border Classes="innerSurface" Padding="14">
                                                                        <StackPanel Spacing="8">
                                                                            <TextBlock Classes="sectionTitle" Text="Relations" />
                                                                            <ListBox x:Name="TopologyRelationListBox" MaxHeight="220" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </StackPanel>
                                                            </ScrollViewer>
                                                        </Grid>
                                                    </Grid>
                                                </desktop:WorkbenchTab>
                                                <desktop:WorkbenchTab Title="MCP 工具">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <StackPanel Margin="16" Spacing="12">
                                                            <Border Classes="innerSurface" Padding="16">
                                                                <StackPanel Spacing="8">
                                                                    <TextBlock Classes="sectionTitle" Text="External Agent Access" />
                                                                    <TextBlock x:Name="ToolingHubText"
                                                                               Classes="secondaryText"
                                                                               TextWrapping="Wrap"
                                                                               Text="Connect Cursor, Codex and other tools through local REST + MCP." />
                                                                </StackPanel>
                                                            </Border>

                                                            <WrapPanel Orientation="Horizontal">
                                                                <Button Classes="primaryAction"
                                                                        Content="Install Cursor"
                                                                        Click="InstallCursor_OnClick"
                                                                        Margin="0,0,8,0" />
                                                                <Button Content="Install Codex"
                                                                        Click="InstallCodex_OnClick"
                                                                        Margin="0,0,8,0" />
                                                                <Button Content="Refresh"
                                                                        Click="RefreshTooling_OnClick"
                                                                        Margin="0,0,8,0" />
                                                                <Button Content="Refresh MCP"
                                                                        Click="RefreshMcpTools_OnClick" />
                                                            </WrapPanel>

                                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                                                <Border Classes="innerSurface" Padding="16">
                                                                    <StackPanel Spacing="8">
                                                                        <TextBlock x:Name="CursorStateText" Classes="cardTitle" Text="Cursor: -" />
                                                                        <TextBlock x:Name="CodexStateText" Classes="cardTitle" Text="Codex: -" />
                                                                        <TextBlock x:Name="ToolingStatusText"
                                                                                   Classes="mutedText"
                                                                                   TextWrapping="Wrap"
                                                                                   Text="Tooling status pending." />
                                                                    </StackPanel>
                                                                </Border>

                                                                <Border Grid.Column="1" Classes="innerSurface" Padding="16">
                                                                    <StackPanel Spacing="8">
                                                                        <TextBlock Classes="sectionTitle" Text="MCP Catalog" />
                                                                        <TextBlock x:Name="McpSummaryText"
                                                                                   Classes="mutedText"
                                                                                   TextWrapping="Wrap"
                                                                                   Text="MCP catalog not loaded." />
                                                                        <ListBox x:Name="McpToolListBox" MaxHeight="280" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </Grid>
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </desktop:WorkbenchTab>
                                            </desktop:WorkbenchTabLayout>
                                        </desktop:WorkbenchWindow.WindowContent>
                                    </desktop:WorkbenchWindow>
                                </desktop:WorkbenchSplitLayout.First>

                                <desktop:WorkbenchSplitLayout.Second>
                                    <desktop:WorkbenchWindow Title="Agent">
                                        <desktop:WorkbenchWindow.WindowContent>
                                            <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
                                                <StackPanel IsVisible="False">
                                                    <TextBlock x:Name="ChatSubtitleText" />
                                                </StackPanel>

                                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="12,12,12,0">
                                                    <TextBlock Classes="sectionTitle"
                                                               VerticalAlignment="Center"
                                                               Text="Agent Session" />
                                                    <Button Grid.Column="1"
                                                            x:Name="ChatSessionsToggleButton"
                                                            Content="Sessions"
                                                            Click="ToggleChatSessions_OnClick" />
                                                    <Button Grid.Column="2"
                                                            x:Name="ChatNewButton"
                                                            Classes="primaryAction"
                                                            Content="New"
                                                            Click="NewChat_OnClick" />
                                                </Grid>

                                                <Border Grid.Row="1" Margin="12,12,12,0" Classes="innerSurface" Padding="10">
                                                    <Grid ColumnDefinitions="*">
                                                        <ComboBox x:Name="ChatProviderBox"
                                                                  SelectionChanged="ChatProviderBox_OnSelectionChanged" />
                                                    </Grid>
                                                </Border>

                                                <Border Grid.Row="2" Margin="12" Classes="innerSurface" Padding="8">
                                                    <Grid>
                                                        <ScrollViewer x:Name="ChatMessagesScrollViewer" VerticalScrollBarVisibility="Auto">
                                                            <StackPanel x:Name="ChatMessagesHost" Spacing="10" />
                                                        </ScrollViewer>
                                                        <ScrollViewer x:Name="ChatSessionsScrollViewer"
                                                                      VerticalScrollBarVisibility="Auto"
                                                                      IsVisible="False">
                                                            <StackPanel x:Name="ChatSessionsHost" Spacing="8" />
                                                        </ScrollViewer>
                                                    </Grid>
                                                </Border>

                                                <TextBlock Grid.Row="3"
                                                           x:Name="ChatStatusText"
                                                           Margin="12,0"
                                                           Classes="mutedText"
                                                           TextWrapping="Wrap"
                                                           Text="Chat ready." />

                                                <Grid Grid.Row="4" Margin="12" RowDefinitions="Auto,Auto" RowSpacing="10">
                                                    <TextBox x:Name="ChatInputBox"
                                                             AcceptsReturn="True"
                                                             Height="92"
                                                             TextWrapping="Wrap"
                                                             Watermark="Type a message..."
                                                             KeyDown="ChatInputBox_OnKeyDown" />
                                                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <Button x:Name="ChatModeAskButton"
                                                                    Classes="chatModeButton"
                                                                    Content="Ask"
                                                                    Click="SwitchChatModeAsk_OnClick" />
                                                            <Button x:Name="ChatModePlanButton"
                                                                    Classes="chatModeButton"
                                                                    Content="Plan"
                                                                    Click="SwitchChatModePlan_OnClick" />
                                                            <Button x:Name="ChatModeAgentButton"
                                                                    Classes="chatModeButton"
                                                                    Content="Agent"
                                                                    Click="SwitchChatModeAgent_OnClick" />
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                x:Name="ChatStopButton"
                                                                Content="Stop"
                                                                Click="StopChat_OnClick"
                                                                IsVisible="False" />
                                                        <Button Grid.Column="2"
                                                                x:Name="ChatSendButton"
                                                                Classes="primaryAction"
                                                                Content="Send"
                                                                Click="SendChatMessage_OnClick" />
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </desktop:WorkbenchWindow.WindowContent>
                                    </desktop:WorkbenchWindow>
                                </desktop:WorkbenchSplitLayout.Second>
                            </desktop:WorkbenchSplitLayout>
                        </desktop:WorkbenchSplitLayout.First>

                        <desktop:WorkbenchSplitLayout.Second>
                            <desktop:WorkbenchWindow Title="日志">
                                <desktop:WorkbenchWindow.WindowContent>
                                    <Grid RowDefinitions="Auto,*" Margin="12">
                                        <StackPanel IsVisible="False">
                                            <TextBlock x:Name="LogFileText" Text="No log file loaded." />
                                        </StackPanel>
                                        <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="8">
                                            <Grid ColumnDefinitions="*">
                                                <TextBlock x:Name="LogStatusText"
                                                           Classes="tertiaryText"
                                                           TextWrapping="Wrap"
                                                           Text="Load a workspace to view runtime logs." />
                                            </Grid>
                                            <TextBox Grid.Row="1"
                                                     x:Name="LogTailBox"
                                                     Classes="logViewer"
                                                     IsReadOnly="True"
                                                     AcceptsReturn="True"
                                                     TextWrapping="NoWrap"
                                                     VerticalContentAlignment="Top"
                                                     HorizontalContentAlignment="Left" />
                                        </Grid>
                                    </Grid>
                                </desktop:WorkbenchWindow.WindowContent>
                            </desktop:WorkbenchWindow>
                        </desktop:WorkbenchSplitLayout.Second>
                    </desktop:WorkbenchSplitLayout>
                </desktop:WorkbenchSplitLayout.Second>
            </desktop:WorkbenchSplitLayout>
        </Grid>
    </Grid>
</Window>
